    "browser_workflow": {
        "step_1": "Read Scout's research brief → identify app category (ai_productivity, fitness_health, etc.)",
        "step_2": "Open this config file → find the matching category in category_to_template_map",
        "step_3": "Note the first_choice template name and the style_filter tag",
        "step_4": "Open browser → navigate to https://appscreens.com/templates",
        "step_5": "Click the 'Tags' dropdown button in the filter toolbar",
        "step_6": "Click the style_filter tag (e.g., 'Top Apps' or 'Dark') from the dropdown menu",
        "step_7": "Scroll through filtered templates → find the first_choice template by name",
        "step_8": "If first_choice not found, try alternatives from the config",
        "step_9": "Click 'Try in Sandbox' on the chosen template card",
        "step_10": "In the sandbox editor, click the device frame placeholder",
        "step_11": "Click 'Upload' or drag screenshots from ~/Documents/LaunchFleet Projects/{appName}/screenshots/",
        "step_12": "Upload screenshots for each panel (up to 10 panels per template)",
        "step_13": "Click on headline text areas → type marketing copy from Buzz's brief",
        "step_14": "Use the device selector to switch between iPhone 6.9\" and iPad 13\"",
        "step_15": "Click 'Export' or 'Download' → select all required sizes",
        "step_16": "Save exported files to ~/Documents/LaunchFleet Projects/{appName}/store-screenshots/",
        "step_17": "If template supports video, upload screen recording from ~/Documents/LaunchFleet Projects/{appName}/recordings/",
        "step_18": "Export video as App Preview (30 seconds max, correct resolution)"
    },
    "expo_simulator_screenshot_paths": {
        "description": "Builder captures these from Expo simulator before handing off to Pixel",
        "screenshots_dir": "~/Documents/LaunchFleet Projects/{appName}/screenshots/",
        "recordings_dir": "~/Documents/LaunchFleet Projects/{appName}/recordings/",
        "capture_command_ios": "xcrun simctl io booted screenshot ~/Documents/LaunchFleet\\ Projects/{appName}/screenshots/{screenName}.png",
        "record_command_ios": "xcrun simctl io booted recordVideo ~/Documents/LaunchFleet\\ Projects/{appName}/recordings/app-preview.mp4",
        "stop_recording": "Press Ctrl+C to stop recording"
    }
}